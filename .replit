modules = ["nodejs-20", "python-3.12", "bash"]
run = "npm install && npm run build && npm start"

[nix]
channel = "stable-25_05"

[deployment]
run = ["sh", "-c", "npm run start:optimized"]

[[ports]]
localPort = 5000
externalPort = 5000

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && npm start"

[workflows.workflow.metadata]
outputType = "console"
