# =========================================
# 🔐 Environment Configuration (.env)
# =========================================
# Rename this file from `sample.env` to `.env`
# Fill in the required values before running the app
# =========================================

# 🧠 Session Configuration (REQUIRED)
SESSION_ID=

# 🔗 Pairing (Optional - if no session ID)
PAIRING_NUMBER=

# 🖼️ API Keys (Optional)
REMOVEBG_KEY=

# 🌐 Server Configuration
PORT=5000

# =========================================
# 🗄️ Database Configuration (Optional)
# Leave empty to use local JSON storage
# =========================================

# 🍃 MongoDB
MONGO_URL=

# 🐘 PostgreSQL
POSTGRES_URL=

# 🐬 MySQL
MYSQL_URL=

# 📁 SQLite (example: ./data/baileys.db)
DB_URL=

# =========================================
# ⚙️ Bot Configuration
# =========================================

# Command prefixes (comma-separated)
PREFIXES=.,!,/

# Bot identity
BOT_NAME=SUBZERO-MD
PACKNAME=SUBZERO-MD

# Owner details
OWNER_NUMBER=263719647303
BOT_OWNER=Darrell

# Mode: private / public
COMMAND_MODE=private

# 🌍 Timezone
TIMEZONE=Africa/Harare
